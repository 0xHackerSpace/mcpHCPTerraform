# Copy this file to .env and fill in the values.
# .env is git-ignored and should never be committed.

# Example: API key for an external service used by your tools
# MY_API_KEY=

# Transport: "stdio" (default) | "sse" | "streamable-http"
# MCP_TRANSPORT=stdio

# Host/port only used when MCP_TRANSPORT=sse or streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8000
